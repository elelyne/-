[
  {
    "id": 1,
    "dimension": "EI",
    "text": "在社交聚會中，你通常會主動與新認識的人交談，很少長時間獨自待著。",
    "direction": "E"
  },
  {
    "id": 2,
    "dimension": "SN",
    "text": "你經常花時間思考那些天馬行空、不切實際但充滿想像力的點子。",
    "direction": "N"
  },
  {
    "id": 3,
    "dimension": "TF",
    "text": "當朋友面臨困境時，你認為先給予情感上的安慰，比立刻幫忙想解決辦法更重要。",
    "direction": "F"
  },
  {
    "id": 4,
    "dimension": "JP",
    "text": "你非常喜歡制定詳細的行程表，並且當計畫被突發狀況打亂時會感到焦慮。",
    "direction": "J"
  },
  {
    "id": 5,
    "dimension": "EI",
    "text": "即便經歷了漫長而疲憊的一週，去參加一場熱鬧的派對仍能讓你感到重獲新生。",
    "direction": "E"
  },
  {
    "id": 6,
    "dimension": "SN",
    "text": "你比較看重眼前的現實數據與具體事實，勝過於探討未來的宏觀趨勢或理論。",
    "direction": "S"
  },
  {
    "id": 7,
    "dimension": "TF",
    "text": "在團隊決策中，你認為「追求邏輯上的正確與公平」，高於「顧及所有人的感受」。",
    "direction": "T"
  },
  {
    "id": 8,
    "dimension": "JP",
    "text": "你傾向於到了最後關頭（Deadline 前夕）才爆發性地完成工作，而不是按部就班。",
    "direction": "P"
  },
  {
    "id": 9,
    "dimension": "EI",
    "text": "你是一個相對安靜、內斂的人，在不熟悉的環境中更傾向於默默觀察。",
    "direction": "I"
  },
  {
    "id": 10,
    "dimension": "SN",
    "text": "閱讀探討宇宙、哲學或生命本質的抽象書籍，會讓你感到興奮且樂在其中。",
    "direction": "N"
  },
  {
    "id": 11,
    "dimension": "TF",
    "text": "看電影或讀小說時，你極度容易感同身受地融入角色的悲傷，甚至落淚。",
    "direction": "F"
  },
  {
    "id": 12,
    "dimension": "JP",
    "text": "你的電腦桌面、房間書桌或手機 App 通常都保持得井然有序、分門別類。",
    "direction": "J"
  },
  {
    "id": 13,
    "dimension": "EI",
    "text": "在團隊討論中，你通常是邊想邊說、主動發言的人，而不是等想完美了才開口。",
    "direction": "E"
  },
  {
    "id": 14,
    "dimension": "SN",
    "text": "你做事情更依賴過往的實務經驗與標準步驟（SOP），不喜歡盲目創新。",
    "direction": "S"
  },
  {
    "id": 15,
    "dimension": "TF",
    "text": "你很難對那些犯了錯但情有可原的人狠下心來，常常容易心軟。",
    "direction": "F"
  },
  {
    "id": 16,
    "dimension": "JP",
    "text": "你喜歡讓生活保持彈性，隨時保留更改計畫的空間，討厭被死板的行程綁死。",
    "direction": "P"
  },
  {
    "id": 17,
    "dimension": "EI",
    "text": "單獨待在家裡一整天不跟任何人說話，會讓你覺得精力被抽空、生活枯燥。",
    "direction": "E"
  },
  {
    "id": 18,
    "dimension": "SN",
    "text": "你經常會沉浸在對未來的憧憬、幻想或各種尚未發生的可能性之中。",
    "direction": "N"
  },
  {
    "id": 19,
    "dimension": "TF",
    "text": "在爭論某件事時，別人的情緒起伏和說話語氣，會比他講的道理更影響你的心情。",
    "direction": "F"
  },
  {
    "id": 20,
    "dimension": "JP",
    "text": "出國旅遊前，你會把每天要去的景點、交通班次和餐廳都調查好並列成清單。",
    "direction": "J"
  },
  {
    "id": 21,
    "dimension": "EI",
    "text": "在社交場合中，你通常是那個比較被動、等待別人來向你搭話的人。",
    "direction": "I"
  },
  {
    "id": 22,
    "dimension": "SN",
    "text": "你非常注重生活用品的實用性與耐用度，勝過於它背後的設計理念或美感。",
    "direction": "S"
  },
  {
    "id": 23,
    "dimension": "TF",
    "text": "當別人表現出辦事不力或缺乏效率時，你會毫不猶豫地指出問題，對事不對人。",
    "direction": "T"
  },
  {
    "id": 24,
    "dimension": "JP",
    "text": "你喜歡速戰速決，一旦事情有了定案，你內心就會感到特別踏實放鬆。",
    "direction": "J"
  },
  {
    "id": 25,
    "dimension": "EI",
    "text": "你擁有一個龐大的朋友圈，並且樂於不斷去結識不同領域的新朋友。",
    "direction": "E"
  },
  {
    "id": 26,
    "dimension": "SN",
    "text": "你常被形容為一個活在當下、腳踏實地，且非常務實的人。",
    "direction": "S"
  },
  {
    "id": 27,
    "dimension": "TF",
    "text": "你非常在乎人際關係的和諧，有時為了不傷害他人，願意隱瞞部分的真相。",
    "direction": "F"
  },
  {
    "id": 28,
    "dimension": "JP",
    "text": "你通常會把需要完成的工作堆到截止日前一天晚上，才在壓力下熬夜完成。",
    "direction": "P"
  },
  {
    "id": 29,
    "dimension": "EI",
    "text": "在一個吵鬧、充滿不熟之人的聚會結束後，你迫切需要一個人安靜地獨處來充電。",
    "direction": "I"
  },
  {
    "id": 30,
    "dimension": "SN",
    "text": "你容易對重複、死板、毫無新意的例行公事和繁瑣細節感到極度不耐煩。",
    "direction": "N"
  },
  {
    "id": 31,
    "dimension": "TF",
    "text": "你認為一間成功的企業，健全的規章制度與績效回報，高於盲目追求人文關懷。",
    "direction": "T"
  },
  {
    "id": 32,
    "dimension": "JP",
    "text": "面對臨時取消的約會或突發的變故，你通常能老神在在、靈活應變。",
    "direction": "P"
  },
  {
    "id": 33,
    "dimension": "EI",
    "text": "在線上或實體會議中，你總是能自然而然地帶動氣氛，成為關注的焦點。",
    "direction": "E"
  },
  {
    "id": 34,
    "dimension": "SN",
    "text": "你習慣於關注事情的全貌（大方向），而非把時間浪費在雕琢微小的細節上。",
    "direction": "N"
  },
  {
    "id": 35,
    "dimension": "TF",
    "text": "你經常會因為太過替別人著想，以致於很難拒絕別人不合理的要求。",
    "direction": "F"
  },
  {
    "id": 36,
    "dimension": "JP",
    "text": "你習慣把每天的待辦事項（To-Do List）寫下來，每勾掉一項就感到很有成就感。",
    "direction": "J"
  },
  {
    "id": 37,
    "dimension": "EI",
    "text": "你更喜歡透過傳訊息、寫文字來表達複雜的情感，而不是直接講電話或當面說。",
    "direction": "I"
  },
  {
    "id": 38,
    "dimension": "SN",
    "text": "如果一個新方法沒有經過歷史數據或前人的實踐證實，你通常會保持強烈懷疑。",
    "direction": "S"
  },
  {
    "id": 39,
    "dimension": "TF",
    "text": "當面臨重大決定時，你認為冷靜客觀的邏輯分析，比盲目聽從內心直覺更靠譜。",
    "direction": "T"
  },
  {
    "id": 40,
    "dimension": "JP",
    "text": "即使是在放假期間，如果生活完全沒有任何結構與計畫，也會讓你感到無所適從。",
    "direction": "J"
  },
  {
    "id": 41,
    "dimension": "EI",
    "text": "你在群組中常常是訊息發得最頻繁、或者在聚會中講話講得最多的那個人。",
    "direction": "E"
  },
  {
    "id": 42,
    "dimension": "SN",
    "text": "你喜歡閱讀科幻、奇幻、推理等充滿世界觀設定，或反轉劇情的作品。",
    "direction": "N"
  },
  {
    "id": 43,
    "dimension": "TF",
    "text": "當看到社會新聞或弱勢群體的慘狀時，你往往會陷入極大的情緒同理與難過之中。",
    "direction": "F"
  },
  {
    "id": 44,
    "dimension": "JP",
    "text": "你是一個喜歡「走一步算一步」的人，遇到事情通常相信自己能臨場發揮得很好。",
    "direction": "P"
  },
  {
    "id": 45,
    "dimension": "EI",
    "text": "對你而言，向不認識的陌生人開啟一段新對話是一件非常耗費心力、痛苦的事情。",
    "direction": "I"
  },
  {
    "id": 46,
    "dimension": "SN",
    "text": "你熱衷於尋找事物與事物之間隱藏的關聯性，擅長從混亂中整理出底層邏輯。",
    "direction": "N"
  },
  {
    "id": 47,
    "dimension": "TF",
    "text": "當被別人批評或工作被全盤否定時，你內心會強烈受挫，甚至覺得對方討厭你這個人。",
    "direction": "F"
  },
  {
    "id": 48,
    "dimension": "JP",
    "text": "你買了書或線上課程後，通常會制定每天要看的進度，並嚴格按時完成。",
    "direction": "J"
  },
  {
    "id": 49,
    "dimension": "EI",
    "text": "在新群體或新班級裡，你通常能在極短的時間內融入大家並打成一片。",
    "direction": "E"
  },
  {
    "id": 50,
    "dimension": "SN",
    "text": "比起大膽且前衛但高風險的投資或計畫，你更偏好穩健、看得到回報的傳統路線。",
    "direction": "S"
  },
  {
    "id": 51,
    "dimension": "TF",
    "text": "在面臨裁員或團隊去留時，你會理性精算出誰對公司最有用，而不是誰最可憐。",
    "direction": "T"
  },
  {
    "id": 52,
    "dimension": "JP",
    "text": "你喜歡保持房間隨性的混亂狀態，覺得這是一種「有秩序的混亂」，不需要刻意收拾。",
    "direction": "P"
  },
  {
    "id": 53,
    "dimension": "EI",
    "text": "你只有在和兩三個最親密的摯友相處時才最自在，其餘時間更喜歡安靜待著。",
    "direction": "I"
  },
  {
    "id": 54,
    "dimension": "SN",
    "text": "你經常會對抽象的哲學概念或沒有標準答案的科學假說產生濃厚的興趣。",
    "direction": "N"
  },
  {
    "id": 55,
    "dimension": "TF",
    "text": "在開會討論時，如果有人講話太過直接、不留情面，即使他是對的，你也會感到反感。",
    "direction": "F"
  },
  {
    "id": 56,
    "dimension": "JP",
    "text": "生活中的例行公事或一成不變的作息，會讓你產生一種像被困在牢籠裡的窒息感。",
    "direction": "P"
  }
]